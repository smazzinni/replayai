// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A logical grouping of agent sessions (e.g. one per agent deployment).
model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  framework   String   @default("Custom")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    Session[]
}

/// A single recorded agent execution — fully replayable.
model Session {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  agent       String
  framework   String
  /// success | failed | running
  status      String
  startedAt   DateTime
  durationMs  Int      @default(0)
  tokenTotal  Int      @default(0)
  costUsd     Float    @default(0)
  /// comma-separated tags (SQLite has no array primitive)
  tags        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  steps       Step[]

  @@index([projectId])
  @@index([status])
  @@index([startedAt])
}

/// A single step within a session: an LLM call, tool call, retrieval, decision, or error.
model Step {
  id          String   @id @default(cuid())
  sessionId   String
  /// ordering index within the session
  order       Int
  /// llm_call | tool_call | retrieval | decision | error
  type        String
  name        String
  /// ms offset from session start
  offsetMs    Int      @default(0)
  durationMs  Int      @default(0)
  /// success | failed | running | warning
  status      String
  model       String?
  tokensIn    Int?
  tokensOut   Int?
  input       String
  output      String
  createdAt   DateTime @default(now())

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  comments    Comment[]

  @@index([sessionId])
  @@index([order])
}

/// Comments on individual steps — for async debugging and team collaboration.
model Comment {
  id          String   @id @default(cuid())
  stepId      String
  sessionId   String
  author      String   @default("anonymous")
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  step        Step     @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@index([stepId])
  @@index([sessionId])
}

/// A workspace-scoped API token used by the SDKs to authenticate session ingestion.
model ApiToken {
  id          String   @id @default(cuid())
  /// The token value shown once at creation; stored hashed (sha256).
  tokenHash   String   @unique
  /// Prefix used for display (e.g. "rai_live_ab12…")
  prefix      String
  name        String   @default("Default")
  /// live | readonly | test
  scope       String   @default("live")
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?
}

/// Design-partner / early-access waitlist entries.
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  company   String?
  role      String?
  teamSize  String?
  useCase   String?
  status    String   @default("pending") // pending | invited | onboarded
  createdAt DateTime @default(now())
}
